---
// الحفاظ على نفس اللون الذهبي الملكي المعتمد في الموقع
const royalGoldGradient = "bg-gradient-to-r from-[#D4AF37] via-[#FFFDF2] to-[#B58500]";
---

<section id="contact" class="py-24 bg-[#01060B] relative overflow-hidden font-['IBM_Plex_Sans_Arabic'] border-t border-white/5">
  
  <div class="absolute inset-0 z-0 pointer-events-none">
    <div class="absolute bottom-0 left-[10%] w-[30%] h-[30%] bg-[#D4AF37]/10 rounded-full blur-[150px] animate-pulse-slow"></div>
    <div class="absolute top-[20%] right-[10%] w-[40%] h-[40%] bg-[#5AC8FA]/10 rounded-full blur-[150px] animate-pulse-slow" style="animation-delay: 2s;"></div>
  </div>

  <div class="container mx-auto px-6 relative z-10">
    
    <div class="text-center mb-16">
      <h2 class="text-4xl md:text-5xl font-bold tracking-tighter inline-block relative text-white drop-shadow-[0_0_25px_rgba(90,200,250,0.4)] mb-4">
        تواصل <span class={`bg-clip-text text-transparent gold-shimmer ${royalGoldGradient}`}>معنا</span>
        <span class="absolute inset-0 bg-[#5AC8FA] blur-[30px] opacity-20 -z-10"></span>
      </h2>
      <p class="text-slate-400 text-lg max-w-2xl mx-auto mt-4">
        نحن هنا لتحويل رؤيتك إلى واقع زجاجي ملموس. فريقنا جاهز للرد على استفساراتكم وتقديم الاستشارات الهندسية.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 max-w-5xl mx-auto">
      
      <div class="group relative p-8 rounded-2xl bg-[#5AC8FA]/[0.02] backdrop-blur-2xl border border-white/5 hover:border-[#D4AF37]/40 transition-all duration-500 hover:-translate-y-2 hover:shadow-[0_15px_30px_rgba(212,175,55,0.15)] text-center overflow-hidden">
        <div class="absolute top-0 left-0 w-full h-1/2 bg-gradient-to-b from-white/5 to-transparent pointer-events-none rounded-t-2xl"></div>
        <div class="w-16 h-16 mx-auto mb-6 rounded-full bg-[#D4AF37]/10 flex items-center justify-center border border-[#D4AF37]/20 group-hover:bg-[#D4AF37]/20 transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-[#D4AF37]" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
          </svg>
        </div>
        <h3 class="text-xl font-bold text-white mb-2">موقعنا</h3>
        <p class="text-slate-400">سوريا، دمشق<br/>القزاز، بجانب صالة البرنسيسة</p>
      </div>

      <div class="group relative p-8 rounded-2xl bg-[#5AC8FA]/[0.04] backdrop-blur-2xl border border-white/10 hover:border-[#5AC8FA]/50 transition-all duration-500 hover:-translate-y-2 hover:shadow-[0_15px_30px_rgba(90,200,250,0.2)] text-center overflow-hidden">
        <div class="absolute inset-0 bg-gradient-to-b from-[#5AC8FA]/10 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500 pointer-events-none"></div>
        <div class="absolute top-0 left-0 w-full h-1/2 bg-gradient-to-b from-white/10 to-transparent pointer-events-none rounded-t-2xl"></div>
        <div class="w-16 h-16 mx-auto mb-6 rounded-full bg-[#5AC8FA]/10 flex items-center justify-center border border-[#5AC8FA]/30 group-hover:bg-[#5AC8FA]/20 transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-[#5AC8FA]" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
          </svg>
        </div>
        <h3 class="text-xl font-bold text-white mb-2">تواصل معنا بشكل مباشر</h3>
        <p class="text-slate-400 mb-6 font-sans" dir="ltr">+963 987 075 648</p>
        <a href="https://wa.me/963999000000" target="_blank" class="inline-block px-6 py-2 rounded-lg bg-[#5AC8FA]/20 text-[#5AC8FA] hover:bg-[#5AC8FA] hover:text-[#01060B] font-bold transition-colors border border-[#5AC8FA]/30">
          راسلنا عبر واتساب الآن
        </a>
      </div>

      <div class="group relative p-8 rounded-2xl bg-[#5AC8FA]/[0.02] backdrop-blur-2xl border border-white/5 hover:border-[#D4AF37]/40 transition-all duration-500 hover:-translate-y-2 hover:shadow-[0_15px_30px_rgba(212,175,55,0.15)] text-center overflow-hidden">
        <div class="absolute top-0 left-0 w-full h-1/2 bg-gradient-to-b from-white/5 to-transparent pointer-events-none rounded-t-2xl"></div>
        <div class="w-16 h-16 mx-auto mb-6 rounded-full bg-[#D4AF37]/10 flex items-center justify-center border border-[#D4AF37]/20 group-hover:bg-[#D4AF37]/20 transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-[#D4AF37]" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
          </svg>
        </div>
        <h3 class="text-xl font-bold text-white mb-2">البريد الإلكتروني</h3>
        <p class="text-slate-400 font-sans">info@goldenglass.sy<br/>sales@goldenglass.sy</p>
      </div>

    </div>
  </div>
</section>

<style>
  .gold-shimmer { background-size: 200% auto; animation: goldShine 4s linear infinite; }
  @keyframes goldShine { to { background-position: 200% center; } }
  
  .animate-pulse-slow {
    animation: slowPulse 8s cubic-bezier(0.4, 0, 0.6, 1) infinite;
  }
  @keyframes slowPulse {
    0%, 100% { opacity: 0.5; transform: scale(1); }
    50% { opacity: 0.8; transform: scale(1.05); }
  }
</style>