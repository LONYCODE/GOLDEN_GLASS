---
// اللون الذهبي الجديد: ذهب ملكي ساطع ومعدني (Royal Luminous Gold)
const royalGoldGradient = "bg-gradient-to-r from-[#D4AF37] via-[#FFFDF2] to-[#B58500]";
---

<section class="relative min-h-screen flex items-center justify-center bg-[#01060B] overflow-hidden font-['IBM_Plex_Sans_Arabic']">
  
  <div class="absolute inset-0 z-0 pointer-events-none">
    <div class="absolute top-[10%] left-[20%] w-[30%] h-[30%] bg-[#D4AF37]/10 rounded-full blur-[120px] animate-pulse-slow"></div>
    <div class="absolute bottom-[10%] right-[20%] w-[40%] h-[40%] bg-[#5AC8FA]/15 rounded-full blur-[150px] animate-pulse-slow" style="animation-delay: 2s;"></div>
    
    <div class="particle absolute top-1/4 left-1/4 w-1.5 h-1.5 bg-white/40 rounded-full shadow-[0_0_10px_#5AC8FA]"></div>
    <div class="particle absolute top-3/4 left-1/3 w-2 h-2 bg-[#D4AF37]/50 rounded-full shadow-[0_0_12px_#D4AF37]" style="animation-delay: 1s; animation-duration: 8s;"></div>
    <div class="particle absolute top-1/2 right-1/4 w-1 h-1 bg-white/60 rounded-full shadow-[0_0_8px_white]" style="animation-delay: 3s;"></div>
    <div class="particle absolute bottom-1/4 right-1/3 w-2.5 h-2.5 bg-[#5AC8FA]/30 rounded-full shadow-[0_0_15px_#5AC8FA]" style="animation-delay: 2s; animation-duration: 9s;"></div>
  </div>

  <div class="absolute inset-0 z-0 pointer-events-none overflow-hidden opacity-40">
    <div class="light-ray absolute top-[-50%] left-[-50%] w-[200%] h-[200%]"></div>
  </div>

  <div class="container mx-auto px-6 relative z-10 text-center">
    
    <h1 class="text-6xl md:text-8xl font-bold mb-8 tracking-tighter leading-tight drop-shadow-2xl">
      <span class={`bg-clip-text text-transparent gold-shimmer ${royalGoldGradient}`}>Golden</span> 
      <span class="text-white drop-shadow-[0_0_25px_rgba(90,200,250,0.4)] relative">
        Glass
        <span class="absolute inset-0 bg-[#5AC8FA] blur-[30px] opacity-20 -z-10"></span>
      </span>
    </h1>
    
    <p class="text-xl md:text-2xl text-slate-200 max-w-3xl mx-auto mb-16 leading-relaxed font-light drop-shadow-md">
        نصمم الفخامة بلمسة زجاجية فريدة. حلول إنشائية متكاملة للزجاج المقسى، تجمع بين هندسة الأمان العالي  وعصرية التصميم.
    </p>

    <div class="flex flex-col md:flex-row gap-10 justify-center items-center">
      
      <a href="#portfolio" class="group relative px-12 py-5 rounded-xl transition-all duration-500 hover:-translate-y-1 shadow-[0_15px_40px_rgba(212,175,55,0.2)] hover:shadow-[0_20px_50px_rgba(212,175,55,0.35)] overflow-hidden">
        <div class={`absolute inset-0 opacity-95 group-hover:opacity-100 transition-opacity duration-500 gold-shimmer ${royalGoldGradient}`}></div>
        <div class="absolute top-0 left-0 w-full h-1/2 bg-white/15 rounded-t-xl"></div>
        <span class="relative z-10 text-[#01060B] font-bold text-xl tracking-wide">عرض أعمالنا</span>
      </a>

      <a href="#contact" class="group relative px-12 py-5 flex items-center justify-center rounded-xl transition-all duration-500 hover:-translate-y-1 hover:shadow-[0_0_30px_rgba(90,200,250,0.25)]">
        
        <div class="absolute inset-0 bg-[#5AC8FA]/[0.02] backdrop-blur-2xl rounded-xl group-hover:bg-[#5AC8FA]/[0.1] transition-colors duration-500"></div>
        
        <div class="absolute inset-0 rounded-xl border border-white/10 group-hover:border-white/40 transition-colors duration-500 shadow-[inset_0_1px_2px_rgba(255,255,255,0.3),inset_0_-1px_1px_rgba(90,200,250,0.15)] pointer-events-none"></div>
        
        <div class="absolute top-0 left-0 w-full h-1/2 bg-gradient-to-b from-white/10 to-transparent pointer-events-none rounded-t-xl"></div>

        <div class="absolute inset-0 overflow-hidden rounded-xl">
          <div class="glass-beam absolute inset-0 w-[200%] h-full opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
        </div>

        <span class="relative z-10 text-[#5AC8FA] group-hover:text-white font-medium text-xl tracking-wide flex items-center gap-3 transition-colors duration-300 drop-shadow-md">
          تواصل معنا
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 transform group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
          </svg>
        </span>
      </a>

    </div>
  </div>
</section>

<style>
  /* لمعان الذهب */
  .gold-shimmer { background-size: 200% auto; animation: goldShine 4s linear infinite; }
  @keyframes goldShine { to { background-position: 200% center; } }

  /* شعاع الزر */
  .glass-beam {
    background: linear-gradient(105deg, transparent 0%, transparent 40%, rgba(255, 255, 255, 0.5) 50%, transparent 60%, transparent 100%);
    transform: translateX(-100%);
    animation: glassBeamSweep 3s infinite;
  }
  @keyframes glassBeamSweep {
    0% { transform: translateX(-100%); }
    20% { transform: translateX(100%); }
    100% { transform: translateX(100%); }
  }

  /* النبض */
  .animate-pulse-slow {
    animation: slowPulse 6s cubic-bezier(0.4, 0, 0.6, 1) infinite;
  }
  @keyframes slowPulse {
    0%, 100% { opacity: 0.5; transform: scale(1); }
    50% { opacity: 0.8; transform: scale(1.05); }
  }

  /* الجزيئات */
  .particle {
    animation: floatParticle 7s ease-in-out infinite;
  }
  @keyframes floatParticle {
    0%, 100% { transform: translateY(0) translateX(0); opacity: 0.3; }
    50% { transform: translateY(-30px) translateX(15px); opacity: 0.8; }
  }

  /* التأثير الزجاجي الجديد: الأشعة المنكسرة في الخلفية */
  .light-ray {
    background: linear-gradient(
      90deg, 
      transparent 0%, 
      rgba(90, 200, 250, 0.03) 30%, 
      rgba(255, 255, 255, 0.08) 50%, 
      rgba(90, 200, 250, 0.03) 70%, 
      transparent 100%
    );
    transform: rotate(35deg);
    animation: sweepRay 15s linear infinite;
  }
  @keyframes sweepRay {
    0% { transform: rotate(35deg) translateY(-100%) translateX(-50%); }
    100% { transform: rotate(35deg) translateY(100%) translateX(50%); }
  }
</style>